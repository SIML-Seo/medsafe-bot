    {
      "name": "explain_medication",
      "title": "의약품 설명 조회",
      "description": "Medsafe Bot(복약안전 봇) retrieves public e약은요 medication guidance for a single itemSeq and returns a concise explanation. Missing public data is reported as not found, not as a tool failure.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "itemSeq": {
            "type": "string",
            "maxLength": 80,
            "pattern": "^(?:\\d{9}|DEMO-[A-Z0-9-]+)$",
            "description": "resolve_medications가 확정한 9자리 품목기준코드"
          }
        },
        "required": [
          "itemSeq"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "info": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "itemSeq": {
                    "type": "string"
                  },
                  "itemName": {
                    "type": "string"
                  },
                  "entpName": {
                    "type": "string"
                  },
                  "efcyQesitm": {
                    "type": "string"
                  },
                  "useMethodQesitm": {
                    "type": "string"
                  },
                  "atpnWarnQesitm": {
                    "type": "string"
                  },
                  "atpnQesitm": {
                    "type": "string"
                  },
                  "intrcQesitm": {
                    "type": "string"
                  },
                  "seQesitm": {
                    "type": "string"
                  },
                  "depositMethodQesitm": {
                    "type": "string"
                  }
                },
                "required": [
                  "itemSeq",
                  "itemName",
                  "entpName"
                ],
                "additionalProperties": false
              },
