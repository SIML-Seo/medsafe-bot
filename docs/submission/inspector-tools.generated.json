    {
      "name": "check_medication_safety",
      "title": "복약 안전 점검",
      "description": "Medsafe Bot(복약안전 봇) checks medication names for DUR contraindications, duplicate ingredients, and unresolved risks. When resolve_medications returns CHECK_MEDICATION_SAFETY_INPUT, call this tool with that queries array only; do not construct medications. The server re-resolves every name and fails closed on ambiguity. Returns a read-only summary with sources, dates, and disclaimers.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "queries": {
            "description": "권장 경로입니다. CHECK_MEDICATION_SAFETY_INPUT의 확정 제품명 queries를 그대로 전달하면 서버가 다시 확인합니다.",
            "minItems": 1,
            "maxItems": 12,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            }
          },
          "medications": {
            "description": "SDK 호환 경로입니다. queries가 있으면 서버는 더 안전한 queries 재확인 경로를 우선합니다.",
            "minItems": 1,
            "maxItems": 12,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "itemSeq": {
                  "description": "resolve_medications가 반환한 itemSeq를 그대로 전달합니다.",
                  "anyOf": [
                    {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 80
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "ingrCode": {
                  "description": "resolve_medications가 반환한 ingrCode를 그대로 전달합니다. 빈 문자열은 null처럼 처리됩니다.",
                  "anyOf": [
                    {
                      "type": "string",
                      "maxLength": 80
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "status": {
                  "description": "resolve_medications가 반환한 status를 그대로 전달합니다.",
                  "type": "string",
                  "enum": [
                    "CONFIRMED",
                    "AMBIGUOUS",
                    "NOT_FOUND",
                    "OUT_OF_SCOPE"
                  ]
                },
                "displayName": {
                  "description": "resolve_medications가 반환한 matchedName 또는 후보명을 그대로 전달합니다.",
                  "anyOf": [
                    {
                      "type": "string",
                      "maxLength": 512
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "confirmationToken": {
                  "description": "SDK 직접 호출 호환 경로에서 resolve_medications가 발급한 값을 그대로 전달합니다.",
                  "anyOf": [
                    {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 512
                    },
                    {
                      "type": "null"
                    }
                  ]
                }
              }
            }
          },
          "context": {
            "type": "object",
            "properties": {
              "ageGroup": {
                "description": "사용자가 복용자의 연령대를 직접 말한 경우만 전달하고, 아니면 unknown 또는 생략합니다.",
                "type": "string",
                "enum": [
                  "adult",
                  "elderly",
                  "child",
                  "unknown"
                ]
              },
              "pregnancy": {
                "description": "사용자가 임신 여부를 직접 말한 경우만 전달하고, 아니면 unknown 또는 생략합니다.",
                "type": "string",
                "enum": [
                  "yes",
                  "no",
                  "unknown"
                ]
              },
              "notes": {
                "description": "응급·과량복용 표현을 포함해 사용자가 말한 추가 문맥을 임의 추론 없이 전달합니다.",
                "anyOf": [
                  {
                    "type": "string",
                    "maxLength": 500
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            }
          }
        },
